{
  "ScrapingIntervalMinutes": 5,
  "TargetUrl": "http://quotes.toscrape.com/",
  "HttpTimeoutSeconds": 30,
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/data/quotes.db"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
